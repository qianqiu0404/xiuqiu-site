{
  "name": "xiuqiu-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run generate:articles && vite",
    "build": "npm run generate:articles && npm run generate:sitemap && npm run check:knowledge && npm run typecheck:api && vue-tsc && vite build && npm run generate:meta-pages",
    "build:vite": "vue-tsc && vite build",
    "generate:articles": "node scripts/generate-articles.mjs",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "generate:meta-pages": "node scripts/generate-meta-pages.mjs",
    "check:knowledge": "node scripts/validate-knowledge.mjs",
    "typecheck:api": "tsc --noEmit --target ES2020 --module ESNext --moduleResolution bundler --allowImportingTsExtensions --skipLibCheck --strict api/chat.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "typescript": "~5.7.3",
    "vite": "^6.3.2",
    "vue-tsc": "^2.2.8"
  }
}
