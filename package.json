{
  "name": "xiuqiu-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run generate:content && vite",
    "build": "npm run generate:content && npm run generate:sitemap && npm run check:knowledge && npm run typecheck:api && vue-tsc && vite build && npm run generate:meta-pages",
    "build:vite": "vue-tsc && vite build",
    "generate:content": "npm run generate:articles && npm run generate:projects && npm run generate:ai && npm run generate:learning && npm run generate:radar && npm run generate:failures && npm run generate:evidence && npm run generate:deliveries && npm run generate:now",
    "generate:articles": "node scripts/generate-articles.mjs",
    "generate:projects": "node scripts/generate-projects.mjs",
    "generate:ai": "node scripts/generate-ai-cases.mjs",
    "generate:learning": "node scripts/generate-learning.mjs",
    "generate:radar": "node scripts/generate-radars.mjs",
    "generate:failures": "node scripts/generate-failure-cases.mjs",
    "generate:evidence": "node scripts/generate-evidence.mjs",
    "generate:deliveries": "node scripts/generate-deliveries.mjs",
    "generate:now": "node scripts/generate-now.mjs",
    "extract:radar": "node scripts/extract-radar-source.mjs",
    "test:radar": "node --test scripts/radar-pipeline.test.mjs",
    "validate:radar": "node scripts/validate-radar-candidate.mjs",
    "sync:learning": "node scripts/sync-learning-from-obsidian.mjs",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "generate:meta-pages": "node scripts/generate-meta-pages.mjs",
    "check:knowledge": "node scripts/validate-knowledge.mjs",
    "check:public": "node scripts/check-public.mjs",
    "check:links": "node scripts/check-portfolio-links.mjs",
    "typecheck:api": "tsc --noEmit --target ES2020 --module ESNext --moduleResolution bundler --allowImportingTsExtensions --skipLibCheck --strict api/chat.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "typescript": "~5.7.3",
    "vite": "^6.3.2",
    "yaml": "^2.9.0",
    "vue-tsc": "^2.2.8"
  }
}
